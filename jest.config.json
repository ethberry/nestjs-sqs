{
  "collectCoverage": true,
  "coverageDirectory": "../coverage",
  "moduleFileExtensions": ["js", "jsx", "ts", "tsx", "json"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "preset": "ts-jest",
  "rootDir": "src",
  "testEnvironment": "node",
  "testMatch": ["**/*.unit.spec.ts", "**/*.integration.spec.ts"],
  "testTimeout": 60000,
  "transform": {
    "^.+\\.[tj]sx?$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/../tsconfig.spec.json"
      }
    ]
  },
  "verbose": true
}
